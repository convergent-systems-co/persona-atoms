---
const title = "PERSONA-Atoms";
const tagline = "Persona primitives for AI agents and LLMs — agentic personas + prompt templates.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={tagline} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={tagline} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={tagline} />
    <title>{title}</title>
    <style>
      :root {
        --bg: #0b0d10;
        --fg: #e8e8e6;
        --muted: #7a8088;
        --accent: #ff79c6;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; background: var(--bg); color: var(--fg); }
      body { min-height: 100vh; display: grid; place-items: center; padding: 2rem; line-height: 1.5; }
      main { max-width: 42rem; text-align: left; }
      h1 { font-size: clamp(2.5rem, 8vw, 4rem); margin: 0 0 0.5rem; font-weight: 600; letter-spacing: -0.03em; }
      .tagline { color: var(--muted); margin: 0 0 2rem; font-size: 1.125rem; }
      .status { border: 1px solid #1f242a; border-left: 3px solid var(--accent); padding: 1rem 1.25rem; background: #11141a; border-radius: 4px; }
      .status p { margin: 0 0 0.5rem; }
      .status p:last-child { margin-bottom: 0; }
      code { background: #1a1f26; padding: 0.1em 0.4em; border-radius: 3px; font-size: 0.9em; }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      footer { color: var(--muted); margin-top: 3rem; font-size: 0.875rem; }
      .types { display: flex; gap: 1rem; margin-top: 1.5rem; }
      .type-card { flex: 1; border: 1px solid #1f242a; padding: 1rem; border-radius: 4px; }
      .type-card h2 { margin: 0 0 0.25rem; font-size: 1rem; color: var(--accent); }
      .type-card p { margin: 0; font-size: 0.875rem; color: var(--muted); }
    </style>
  </head>
  <body>
    <main>
      <h1>{title}</h1>
      <p class="tagline">{tagline}</p>
      <div class="status">
        <p><strong>Status:</strong> bootstrap. Top-level types per the <a href="https://github.com/convergent-systems-co/atoms/blob/main/docs/superpowers/specs/2026-05-23-atoms-type-taxonomy-design.md">v0.1 taxonomy spec</a> are <code>agentic</code> (with <code>actor</code> + <code>reviewer</code> sub-types) and <code>prompt</code>.</p>
        <p>Source: <a href="https://github.com/convergent-systems-co/persona-atoms">github.com/convergent-systems-co/persona-atoms</a></p>
      </div>
      <div class="types">
        <div class="type-card">
          <h2>agentic</h2>
          <p>Identities an AI takes on — actor personas and reviewer personas.</p>
        </div>
        <div class="type-card">
          <h2>prompt</h2>
          <p>Reusable invocation templates applied to work.</p>
        </div>
      </div>
      <footer>
        Part of the <a href="https://github.com/convergent-systems-co/atoms">atoms ecosystem</a>.
        Apache-2.0.
      </footer>
    </main>
  </body>
</html>
