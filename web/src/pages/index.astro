---
const title = "PERSONA-Atoms";
const tagline = "Persona primitives for AI agents and LLMs — agentic personas + prompt templates.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={tagline} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="https://brand-atoms.com/dist/brands/atom-family/1.0.0/assets/favicon.svg" />
    <link rel="preconnect" href="https://brand-atoms.com" />
    <link rel="stylesheet" href="https://brand-atoms.com/dist/brands/atom-family/1.0.0/css/tokens.css" />
    <link rel="stylesheet" href="https://brand-atoms.com/dist/brands/atom-family/1.0.0/ui/atoms-catalog.css" />
    <style>
      body { min-height: 100vh; }
      .hero-mark { width: 160px; height: 160px; margin-bottom: 20px; object-fit: contain; }
      .sidenav-wordmark { width: 140px; object-fit: contain; display: block; }
    </style>
  </head>
  <body>
    <div class="shell">
      <main class="content">
        <section class="hero">
          <img src="https://brand-atoms.com/dist/brands/atom-family/1.0.0/assets/atom-family-icon.png" alt="atom-family" class="hero-mark" />
          <h1>{title}</h1>
          <p class="lede">{tagline}</p>
        </section>
        <div class="status">
          <p><strong>Status:</strong> bootstrap. Top-level types per the <a href="https://github.com/convergent-systems-co/atoms/blob/main/docs/superpowers/specs/2026-05-23-atoms-type-taxonomy-design.md">v0.1 taxonomy spec</a> are <code>agentic</code> (with <code>actor</code> + <code>reviewer</code> sub-types) and <code>prompt</code>.</p>
          <p>Source: <a href="https://github.com/convergent-systems-co/persona-atoms">github.com/convergent-systems-co/persona-atoms</a></p>
        </div>
        <div class="types">
          <div class="type-card">
            <h2>agentic</h2>
            <p>Identities an AI takes on — actor personas and reviewer personas.</p>
          </div>
          <div class="type-card">
            <h2>prompt</h2>
            <p>Reusable invocation templates applied to work.</p>
          </div>
        </div>
        <footer>
          Part of the <a href="https://github.com/convergent-systems-co/atoms">atoms ecosystem</a>. Apache-2.0.
        </footer>
      </main>
      <nav class="sidenav">
        <a class="brand" href="/">
          <img src="https://brand-atoms.com/dist/brands/atom-family/1.0.0/assets/atom-family-wordmark.png" alt="ATOMS" class="sidenav-wordmark" />
        </a>
        <div class="aside-meta">
          <a class="meta-link" href="https://github.com/convergent-systems-co/persona-atoms">github ↗</a>
        </div>
      </nav>
    </div>
  </body>
</html>
