---
import Base from "../../layouts/Base.astro";
import catalog from "../../../public/exports/catalog.json";

export function getStaticPaths() {
  return catalog.personas.map((composition: any) => ({
    params: { id: composition.id },
    props: { composition },
  }));
}

const { composition } = Astro.props;
const refs = {
  role_definition: composition.role_definition,
  voice_profile: composition.voice_profile,
  tone_parameters: composition.tone_parameters,
  work_contract: composition.work_contract,
  behavioural_constraints: composition.behavioural_constraints ?? [],
  knowledge_boundaries: composition.knowledge_boundaries ?? [],
};
const refEntries = Object.entries(refs).filter(([, val]) =>
  Array.isArray(val) ? val.length > 0 : Boolean(val)
);
---
<Base title={composition.name} description={composition.description}>
  <p><a href="/personas/">← All personas</a></p>
  <h1>{composition.name}</h1>
  <p style="color: var(--muted);">
    <code>persona</code>
    {composition.class && <> · <code>{composition.class}</code></>}
    {composition.domain && <> · <code>{composition.domain}</code></>}
    · <code>v{composition.version}</code>
  </p>

  {composition.description && <p>{composition.description}</p>}

  {refEntries.length > 0 && (
    <section>
      <h2>References</h2>
      {refEntries.map(([key, val]: [string, any]) => {
        const values: any[] = Array.isArray(val) ? val : [val];
        return (
          <div style="margin-bottom: 1.5rem;">
            <h3 style="margin-bottom: 0.5rem; text-transform: capitalize;">{key.replace(/_/g, " ")}</h3>
            <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
              {values.map((r: any) => (
                <span style="font-size: 0.875rem; background: #f4ece4; padding: 0.25rem 0.75rem; border-radius: 0.25rem; font-family: monospace;">
                  {r.ref} @ v{r.version}
                </span>
              ))}
            </div>
          </div>
        );
      })}
    </section>
  )}

  <h2>Raw composition</h2>
  <p><a href={`/personas/${composition.id}/atom.json`}>/personas/{composition.id}/atom.json</a> · <a href="/schemas/composition-v1.json">schema</a></p>
</Base>
